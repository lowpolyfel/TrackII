@using System.Text.Json
@model Trackii.Models.Gerencia.GerenciaDiscreteMapVm
@using System.Globalization
@{
    ViewData["Title"] = "Mapa de Discretos";
    var spanish = new CultureInfo("es-MX");

    string ShortSubfamily(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "-";
        if (name.Length <= 14) return name;

        var words = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (words.Length > 1)
        {
            var acronym = string.Concat(words.Select(word => char.ToUpperInvariant(word[0])));
            if (acronym.Length >= 2 && acronym.Length <= 8)
            {
                return acronym;
            }
        }

        return name[..12] + "…";
    }

    var shortNames = Model.Matrix.Subfamilies.ToDictionary(name => name, ShortSubfamily);
    var metricLabel = Model.MetricView == "orders" ? "ÓRDENES" : "PIEZAS";
    var rowTotalLabel = Model.MetricView == "orders" ? "Total órdenes" : "Total piezas";
}

<div class="page-header error-causes-header">
    <div>
        <h2>Mapa de Discretos</h2>
    </div>
    <a asp-controller="Gerencia" asp-action="Index" class="btn btn-secondary"><i class="fa-solid fa-arrow-left"></i> Volver</a>
</div>

<style>
    /* Cuadrícula proporcionada, manteniendo la misma altura sin hacerse gigantes */
    @@media (min-width: 1024px) {
        .discrete-overview-grid {
            grid-template-columns: 32% 68% !important;
            align-items: stretch !important;
            margin-top: 30px;
        }
    }

    #summaryPanel, #scrapPanel {
        display: flex;
        flex-direction: column;
    }
</style>

<div id="mapPanel">
    <form method="get" class="js-async-discrete-form" data-target="#mapPanel" style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 25px; flex-wrap: wrap; gap: 20px;">
        
        <div class="d-flex align-items-center gap-2">
            <div class="input-group input-group-sm shadow-sm" style="width: auto;">
                <span class="input-group-text bg-white text-muted"><i class="fa-regular fa-calendar"></i></span>
                <input type="date" name="fromDate" value="@(Model.FromDate?.ToString("yyyy-MM-dd"))" class="form-control" />
                <span class="input-group-text bg-white text-muted border-start-0 border-end-0"><i class="fa-solid fa-arrow-right"></i></span>
                <input type="date" name="toDate" value="@(Model.ToDate?.ToString("yyyy-MM-dd"))" class="form-control" />
                <button type="submit" name="periodType" value="custom" class="btn @(Model.QuickRange == "custom" ? "btn-primary" : "btn-dark")">Filtrar</button>
            </div>
        </div>

        <div style="display: flex; flex-direction: column; gap: 12px; align-items: flex-end;">
            <div class="btn-group shadow-sm" role="group" aria-label="Cambiar métrica del mapa">
                <button type="submit" name="metricView" value="pieces" class="btn btn-sm @(Model.MetricView == "pieces" ? "btn-dark" : "btn-outline-dark")"><i class="fa-solid fa-puzzle-piece"></i> Piezas</button>
                <button type="submit" name="metricView" value="orders" class="btn btn-sm @(Model.MetricView == "orders" ? "btn-dark" : "btn-outline-dark")"><i class="fa-solid fa-list-check"></i> Órdenes</button>
            </div>

            <div class="btn-group shadow-sm" role="group" aria-label="Rango rápido del mapa">
                <button class="btn btn-sm @(Model.QuickRange == "day" ? "btn-primary" : "btn-outline-secondary")" type="submit" name="periodType" value="day">Día</button>
                <button class="btn btn-sm @(Model.QuickRange == "week" ? "btn-primary" : "btn-outline-secondary")" type="submit" name="periodType" value="week">Semana</button>
                <button class="btn btn-sm @(Model.QuickRange == "month" ? "btn-primary" : "btn-outline-secondary")" type="submit" name="periodType" value="month">Mes</button>
                <button class="btn btn-sm @(Model.QuickRange == "historic" ? "btn-primary" : "btn-outline-secondary")" type="submit" name="periodType" value="historic">Anual</button>
            </div>
        </div>
        
        <input type="hidden" name="sortBy" value="@Model.SortBy" />
    </form>

    <div class="table-wrapper discrete-map-wrapper">
        <table class="table gerencia-weekly-table discrete-map-table">
            <thead>
                <tr>
                    <th>Localidad</th>
                    @foreach (var subfamily in Model.Matrix.Subfamilies)
                    {
                        <th title="@subfamily">@shortNames[subfamily]</th>
                    }
                    <th>@rowTotalLabel</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Matrix.Rows.Any())
                {
                    <tr>
                        <td colspan="@(Model.Matrix.Subfamilies.Count + 2)" class="empty">No hay localidades con rutas activas para el corte seleccionado.</td>
                    </tr>
                }
                else
                {
                    @foreach (var row in Model.Matrix.Rows)
                    {
                        <tr>
                            <td>@row.Location</td>
                            @foreach (var cell in row.Cells)
                            {
                                var zeroClass = cell.Pieces == 0 ? "cell-zero" : string.Empty;
                                var metricValue = Model.MetricView == "orders" ? cell.Orders : cell.Pieces;
                                zeroClass = metricValue == 0 ? "cell-zero" : string.Empty;
                                <td class="@zeroClass">
                                    @if (metricValue == 0)
                                    {
                                        <span class="zero-mask" aria-hidden="true"></span>
                                    }
                                    else
                                    {
                                        <a asp-controller="Gerencia"
                                               asp-action="DiscreteMapDetail"
                                               asp-route-location="@row.Location"
                                               asp-route-subfamily="@cell.Subfamily"
                                               asp-route-periodType="@Model.PeriodType"
                                               asp-route-weekValue="@Model.WeekValue"
                                               asp-route-monthValue="@Model.MonthValue"
                                               asp-route-fromDate="@(Model.FromDate?.ToString("yyyy-MM-dd"))"
                                               asp-route-toDate="@(Model.ToDate?.ToString("yyyy-MM-dd"))"
                                               class="cell-link-strong">
                                            @metricValue.ToString("N0")
                                        </a>
                                    }
                                </td>
                            }
                            <td><strong>@(Model.MetricView == "orders" ? row.TotalOrders.ToString("N0") : row.TotalPieces.ToString("N0"))</strong></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<section class="discrete-overview-grid" aria-label="Resumen ejecutivo discretos">
    
    <article id="summaryPanel"
             class="kpi-highlight apple-card error-kpi-card compact-executive-card"
             data-order-labels="@JsonSerializer.Serialize(Model.OrdersSummaryChart.Labels)"
             data-order-values="@JsonSerializer.Serialize(Model.OrdersSummaryChart.Values)">
            
        <div class="compact-executive-header" style="display: flex; flex-direction: column; gap: 12px; border-bottom: 1px solid #eee; padding-bottom: 15px; margin-bottom: 20px;">
            <span class="kpi-label" style="font-size: 1.1rem; font-weight: 600; color: #1e293b;">Resumen General</span>
            <form method="get" class="quick-range-form js-async-discrete-form" data-target="#summaryPanel">
                <div class="btn-group shadow-sm w-100" role="group" aria-label="Rango rápido">
                    <button class="btn btn-sm @(Model.QuickRange == "day" ? "btn-primary" : "btn-outline-secondary")" type="submit" name="periodType" value="day">Día</button>
                    <button class="btn btn-sm @(Model.QuickRange == "week" ? "btn-primary" : "btn-outline-secondary")" type="submit" name="periodType" value="week">Semana</button>
                    <button class="btn btn-sm @(Model.QuickRange == "month" ? "btn-primary" : "btn-outline-secondary")" type="submit" name="periodType" value="month">Mes</button>
                    <button class="btn btn-sm @(Model.QuickRange == "historic" ? "btn-primary" : "btn-outline-secondary")" type="submit" name="periodType" value="historic">Anual</button>
                </div>
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                <input type="hidden" name="metricView" value="@Model.MetricView" />
            </form>
        </div>

        <div class="compact-executive-body" style="display: grid; grid-template-columns: 1fr; gap: 20px;">
            <div class="kpi-metrics-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                <div class="kpi-box" style="background: #f8fafc; padding: 12px; border-radius: 8px; border-left: 4px solid #3b82f6;">
                    <span style="display: block; color: #64748b; font-size: 0.70rem; font-weight: bold; text-transform: uppercase;">Piezas</span>
                    <strong style="font-size: 1.5rem; color: #0f172a; line-height: 1.1;">@Model.Matrix.TotalPieces.ToString("N0")</strong>
                </div>
                <div class="kpi-box" style="background: #f8fafc; padding: 12px; border-radius: 8px; border-left: 4px solid #10b981;">
                    <span style="display: block; color: #64748b; font-size: 0.70rem; font-weight: bold; text-transform: uppercase;">Órdenes</span>
                    <strong style="font-size: 1.5rem; color: #0f172a; line-height: 1.1;">@Model.Matrix.TotalOrders.ToString("N0")</strong>
                </div>
                <div class="kpi-box" style="background: #f8fafc; padding: 12px; border-radius: 8px; border-left: 4px solid #8b5cf6;">
                    <span style="display: block; color: #64748b; font-size: 0.70rem; font-weight: bold; text-transform: uppercase;">Prod.</span>
                    <strong style="font-size: 1.5rem; color: #0f172a; line-height: 1.1;">@Model.ProducedTotal.ToString("N0")</strong>
                </div>
                <div class="kpi-box" style="background: #fcf1f1; padding: 12px; border-radius: 8px; border-left: 4px solid #ef4444;">
                    <span style="display: block; color: #ef4444; font-size: 0.70rem; font-weight: bold; text-transform: uppercase;">Scrap</span>
                    <strong style="font-size: 1.5rem; color: #7f1d1d; line-height: 1.1;">@Model.ScrapTotal.ToString("N0")</strong>
                </div>
            </div>
            <div id="ordersSummaryChart" class="mini-chart-host" aria-label="Estado general de órdenes" style="display: flex; justify-content: center;"></div>
        </div>
    </article>

    <article id="scrapPanel" class="kpi-highlight apple-card error-kpi-card compact-scrap-card"
             data-chart-labels="@JsonSerializer.Serialize(Model.ProductionTrendChart.Labels)"
             data-chart-production="@JsonSerializer.Serialize(Model.ProductionTrendChart.Values)"
             data-chart-scrap="@JsonSerializer.Serialize(Model.ScrapTrendChart.Values)">
            
        <div class="compact-executive-header" style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #eee; padding-bottom: 15px; margin-bottom: 10px;">
            <span class="kpi-label" style="font-size: 1.1rem; font-weight: 600; color: #1e293b;">Scrap vs Producción</span>
            <form method="get" class="quick-range-form js-async-discrete-form" data-target="#scrapPanel" style="display: flex; gap: 15px; align-items: center;">
                <select id="selectedSubfamily" name="selectedSubfamily" class="form-select form-select-sm shadow-sm" onchange="this.form.requestSubmit();" style="width: auto; min-width: 120px;">
                    @foreach (var subfamily in Model.Matrix.Subfamilies)
                    {
                        if (Model.SelectedSubfamily == subfamily)
                        {
                            <option value="@subfamily" selected="selected">@subfamily</option>
                        }
                        else
                        {
                            <option value="@subfamily">@subfamily</option>
                        }
                    }
                </select>

                <div class="btn-group shadow-sm" role="group" aria-label="Rango rápido de scrap">
                    <button class="btn btn-sm @(Model.QuickRange == "day" ? "btn-primary" : "btn-outline-secondary")" type="submit" name="periodType" value="day">Día</button>
                    <button class="btn btn-sm @(Model.QuickRange == "week" ? "btn-primary" : "btn-outline-secondary")" type="submit" name="periodType" value="week">Semana</button>
                    <button class="btn btn-sm @(Model.QuickRange == "month" ? "btn-primary" : "btn-outline-secondary")" type="submit" name="periodType" value="month">Mes</button>
                    <button class="btn btn-sm @(Model.QuickRange == "historic" ? "btn-primary" : "btn-outline-secondary")" type="submit" name="periodType" value="historic">Anual</button>
                </div>
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                <input type="hidden" name="metricView" value="@Model.MetricView" />
            </form>
        </div>
        
        <div id="scrapVsProductionChart" class="chart-host compact-line-chart" style="width: 100%;"></div>
    </article>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
    <script>
        let ordersChart = null;
        let scrapChart = null;

        function initOrdersChart() {
        const summaryPanel = document.getElementById('summaryPanel');
        const ordersSummaryContainer = document.getElementById('ordersSummaryChart');
        if (!ordersSummaryContainer || !summaryPanel) return;
        const orderStatusLabels = JSON.parse(summaryPanel.dataset.orderLabels ?? '[]');
        const orderStatusValues = JSON.parse(summaryPanel.dataset.orderValues ?? '[]');
            
        if (ordersChart) ordersChart.destroy();
        ordersSummaryContainer.innerHTML = '';
        ordersChart = new ApexCharts(ordersSummaryContainer, {
        chart: { type: 'donut', height: 260, toolbar: { show: false }, fontFamily: 'Inter, sans-serif' },
        labels: orderStatusLabels,
        series: orderStatusValues,
        legend: { position: 'bottom', fontSize: '12px', itemMargin: { horizontal: 10, vertical: 5 } },
        colors: ['#3078ff', '#f59e0b', '#ff6b6b', '#25b46b'],
        stroke: { width: 2, colors: ['#fff'] },
        dataLabels: { enabled: false },
        plotOptions: { pie: { donut: { size: '70%' } } }
        });
        ordersChart.render();
        }

        function initScrapChart() {
        const scrapPanel = document.getElementById('scrapPanel');
        const scrapVsProductionContainer = document.getElementById('scrapVsProductionChart');
        if (!scrapPanel || !scrapVsProductionContainer) return;

        const productionTrendLabels = JSON.parse(scrapPanel.dataset.chartLabels ?? '[]');
        const productionTrendValues = JSON.parse(scrapPanel.dataset.chartProduction ?? '[]');
        const scrapTrendValues = JSON.parse(scrapPanel.dataset.chartScrap ?? '[]');

        if (scrapChart) scrapChart.destroy();
        scrapVsProductionContainer.innerHTML = '';
        scrapChart = new ApexCharts(scrapVsProductionContainer, {
        chart: { type: 'area', height: 280, toolbar: { show: false }, fontFamily: 'Inter, sans-serif' },
        series: [
        { name: 'Producción', data: productionTrendValues },
        { name: 'Scrap', data: scrapTrendValues }
        ],
        colors: ['#10b981', '#ef4444'],
        stroke: { width: 2, curve: 'smooth' },
        markers: { size: 0 },
        xaxis: {
        categories: productionTrendLabels,
        tooltip: { enabled: false }
        },
        yaxis: [{ title: { text: 'Cantidad' } }],
        dataLabels: { enabled: false },
        fill: { type: 'solid', opacity: 0.25 },
        legend: { position: 'top', horizontalAlign: 'right' }
        });
        scrapChart.render();
        }

        async function handleAsyncFormSubmit(event) {
        event.preventDefault();
        const form = event.currentTarget;
        const targetSelector = form.dataset.target;
        if (!targetSelector) return;

        const submitter = event.submitter;
        const params = new URLSearchParams(new FormData(form));

        // Asegurar que guardamos el periodo correcto al enviar por botones
        if (submitter && submitter.name) {
        params.set(submitter.name, submitter.value);
        }
            
        // Si hacemos clic en Órdenes/Piezas, buscamos el periodo de tiempo activo
        if (!params.has('periodType')) {
        const activeBtn = form.querySelector('button.btn-primary[name="periodType"]');
        if (activeBtn) {
        params.set('periodType', activeBtn.value);
        } else if (params.get('fromDate') && params.get('toDate')) {
        // Si tiene fechas, asumimos que es custom
        params.set('periodType', 'custom');
        }
        }

        const url = `${form.action || window.location.pathname}?${params.toString()}`;
        const response = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
        if (!response.ok) return;

        const html = await response.text();
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');
        const newTarget = doc.querySelector(targetSelector);
        const currentTarget = document.querySelector(targetSelector);
        if (!newTarget || !currentTarget) return;

        currentTarget.outerHTML = newTarget.outerHTML;
        bindAsyncForms();
        initOrdersChart();
        initScrapChart();
        }

        function bindAsyncForms() {
        document.querySelectorAll('.js-async-discrete-form').forEach(form => {
        form.removeEventListener('submit', handleAsyncFormSubmit);
        form.addEventListener('submit', handleAsyncFormSubmit);
        });
        }

        bindAsyncForms();
        initOrdersChart();
        initScrapChart();
    </script>
}