@using System.Text.Json
@model Trackii.Models.Gerencia.GerenciaErrorCausesVm
@{
    ViewData["Title"] = "Causas de errores";
}
<div class="dashboard">
    <div class="page-header">
        <div><h2>Causas de errores más grandes</h2><p class="subtitle">Top de scrap acumulado por código/categoría desde <strong>scrap_log</strong>.</p></div>
        <a asp-controller="Gerencia" asp-action="Index" class="btn btn-secondary"><i class="fa-solid fa-arrow-left"></i> Volver</a>
    </div>

    <div class="chart-grid">
        <div class="card chart-card apple-card error-causes-card">
            <h3>Scrap por causa</h3>
            <div id="errorsChart" class="chart-host"></div>
        </div>
        <div class="card apple-card error-causes-card">
            <h3>Detalle por causa</h3>
            <div class="table-wrapper"><table class="table"><thead><tr><th>Causa</th><th>Scrap</th><th>Eventos</th></tr></thead><tbody>
                @if (!Model.Causes.Any())
                {
                    <tr><td colspan="3" class="empty">Sin datos en scrap_log para mostrar causas.</td></tr>
                }
                else
                {
                    @foreach (var item in Model.Causes) { <tr><td>@item.Cause</td><td>@item.Qty</td><td>@item.Events</td></tr> }
                }
            </tbody></table></div>
        </div>
    </div>

    <div class="chart-grid">
        <div class="card chart-card apple-card error-causes-card">
            <h3>Localidades con más scrap</h3>
            <div id="scrapLocationChart" class="chart-host"></div>
        </div>
        <div class="card apple-card error-causes-card">
            <h3>Top localidades</h3>
            <div class="table-wrapper">
                <table class="table">
                    <thead><tr><th>Localidad</th><th>Scrap</th><th>Eventos</th></tr></thead>
                    <tbody>
                        @if (!Model.Locations.Any())
                        {
                            <tr><td colspan="3" class="empty">Sin localidades con scrap registradas.</td></tr>
                        }
                        else
                        {
                            @foreach (var loc in Model.Locations)
                            {
                                <tr><td>@loc.Location</td><td>@loc.Qty</td><td>@loc.Events</td></tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
<script>
const causeLabels = @Html.Raw(JsonSerializer.Serialize(Model.CausesChart.Labels));
const causeValues = @Html.Raw(JsonSerializer.Serialize(Model.CausesChart.Values));
const locationLabels = @Html.Raw(JsonSerializer.Serialize(Model.LocationScrapChart.Labels));
const locationValues = @Html.Raw(JsonSerializer.Serialize(Model.LocationScrapChart.Values));

new ApexCharts(document.getElementById('errorsChart'), {
    chart: { type: 'bar', height: 300, toolbar: { show: false }, fontFamily: 'Inter, sans-serif' },
    series: [{ name: 'Scrap', data: causeValues }],
    colors: ['#f26d6d'],
    plotOptions: { bar: { borderRadius: 8, columnWidth: '56%' } },
    legend: { show: false },
    xaxis: { categories: causeLabels, labels: { rotate: -20, trim: true, style: { fontSize: '11px', fontWeight: 600 } } },
    yaxis: { labels: { style: { colors: '#5f7392' } } },
    grid: { borderColor: 'rgba(80, 110, 150, 0.12)', strokeDashArray: 4 }
}).render();

new ApexCharts(document.getElementById('scrapLocationChart'), {
    chart: { type: 'bar', height: 300, toolbar: { show: false }, fontFamily: 'Inter, sans-serif' },
    series: [{ name: 'Scrap', data: locationValues }],
    colors: ['#ff9f43'],
    plotOptions: { bar: { borderRadius: 8, horizontal: true, barHeight: '58%' } },
    legend: { show: false },
    xaxis: { categories: locationLabels, labels: { style: { colors: '#5f7392' } } },
    yaxis: { labels: { style: { colors: '#4d6283', fontSize: '12px', fontWeight: 600 } } },
    grid: { borderColor: 'rgba(80, 110, 150, 0.12)', strokeDashArray: 4 }
}).render();
</script>
}
