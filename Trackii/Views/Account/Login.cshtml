@model Trackii.Models.LoginVm
@{
    ViewData["Title"] = "Login";
    Layout = "_AuthLayout";
}

<div class="auth-page auth-page-modern">
    <div class="auth-card auth-card-modern">
        <section class="auth-form auth-form-modern">
            <div class="auth-brand auth-brand-modern">
                <span class="auth-logo"><i class="fa-solid fa-cubes"></i></span>
                <span class="auth-title">Template<br />Design</span>
            </div>

            <div class="auth-avatar auth-avatar-modern">
                <i class="fa-regular fa-user"></i>
            </div>

            <form method="post" asp-action="Login" class="auth-fields auth-fields-modern">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" />

                <div class="auth-pill-field">
                    <i class="fa-regular fa-user"></i>
                    <input asp-for="Username" class="auth-input auth-input-pill" placeholder="USERNAME" autocomplete="username" />
                </div>
                <span asp-validation-for="Username" class="auth-error"></span>

                <div class="auth-pill-field">
                    <i class="fa-solid fa-lock"></i>
                    <input asp-for="Password" class="auth-input auth-input-pill" placeholder="PASSWORD" autocomplete="current-password" />
                </div>
                <span asp-validation-for="Password" class="auth-error"></span>

                <button type="submit" class="auth-button auth-button-pill">Login</button>

                <div class="auth-meta auth-meta-modern">
                    <label class="auth-remember">
                        <input asp-for="RememberMe" />
                        <span>@Html.DisplayNameFor(m => m.RememberMe)</span>
                    </label>
                    <span class="auth-hint">Forgot your password?</span>
                </div>

                <div class="auth-error">
                    @Html.ValidationSummary(false)
                </div>
            </form>

            <div class="auth-dots" aria-hidden="true"><span></span><span></span><span></span></div>
        </section>

        <section class="auth-welcome auth-welcome-modern">
            <nav class="auth-top-links" aria-label="Navegación">
                <a href="#">About</a>
                <a href="#">Download</a>
                <a href="#">Pricing</a>
                <a href="#">Contact</a>
                <span class="auth-signin-pill">Sign in</span>
                <i class="fa-solid fa-bars"></i>
            </nav>

            <div class="auth-welcome-content auth-welcome-content-modern">
                <h2>Welcome.</h2>
                <p>Espacio visual renovado para acceso de usuarios.</p>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
