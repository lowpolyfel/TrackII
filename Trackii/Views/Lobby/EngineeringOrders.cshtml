@model Trackii.Models.Engineering.EngineeringActiveOrdersVm

@{
    ViewData["Title"] = "Órdenes activas";
}

<div class="dashboard">
    <div class="page-header">
        <div>
            <h2>Dashboard de órdenes activas</h2>
            <p class="subtitle">Clasifica órdenes por familia, subfamily, localidad y ruta para detectar carga y destino operativo.</p>
        </div>
        <div class="header-actions">
            <a asp-controller="Lobby" asp-action="Index" class="btn btn-secondary">
                <i class="fa-solid fa-arrow-left"></i>
                Volver al lobby
            </a>
        </div>
    </div>

    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-icon"><i class="fa-solid fa-list-check"></i></div>
            <div class="kpi-content">
                <div class="kpi-title">Órdenes activas</div>
                <div class="kpi-value">@Model.ActiveOrdersCount</div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon"><i class="fa-solid fa-layer-group"></i></div>
            <div class="kpi-content">
                <div class="kpi-title">Families involucradas</div>
                <div class="kpi-value">@Model.DistinctFamiliesCount</div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon"><i class="fa-solid fa-sitemap"></i></div>
            <div class="kpi-content">
                <div class="kpi-title">Subfamilies activas</div>
                <div class="kpi-value">@Model.DistinctSubfamiliesCount</div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon"><i class="fa-solid fa-route"></i></div>
            <div class="kpi-content">
                <div class="kpi-title">Rutas activas</div>
                <div class="kpi-value">@Model.DistinctRoutesCount</div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon"><i class="fa-solid fa-location-dot"></i></div>
            <div class="kpi-content">
                <div class="kpi-title">Localidades activas</div>
                <div class="kpi-value">@Model.DistinctLocationsCount</div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="page-header">
            <div>
                <h3>Filtros de clasificación</h3>
                <p class="subtitle">Usa las listas desplegables para ver qué órdenes van por una familia, ruta o localidad específica.</p>
            </div>
        </div>

        <form method="get" class="filters">
            <input type="search" name="search" value="@Model.Search" placeholder="Buscar WO o producto..." />

            <select name="status">
                <option value="">Todos los estados activos</option>
                <option value="OPEN" selected="@(Model.Status == "OPEN")">OPEN</option>
                <option value="IN_PROGRESS" selected="@(Model.Status == "IN_PROGRESS")">IN_PROGRESS</option>
            </select>

            <select name="familyId" id="familyFilter">
                <option value="">Todas las families</option>
                @foreach (var item in Model.Families)
                {
                    <option value="@item.Id" selected="@(Model.FamilyId == item.Id)">@item.Name (@item.Count)</option>
                }
            </select>

            <select name="subfamilyId" id="subfamilyFilter">
                <option value="">Todas las subfamilies</option>
                @foreach (var item in Model.Subfamilies)
                {
                    <option value="@item.Id"
                            data-family-id="@item.FamilyId"
                            selected="@(Model.SubfamilyId == item.Id)">
                        @item.Name (@item.Count)
                    </option>
                }
            </select>

            <select name="routeId">
                <option value="">Todas las rutas</option>
                @foreach (var item in Model.Routes)
                {
                    <option value="@item.Id" selected="@(Model.RouteId == item.Id)">@item.Name (@item.Count)</option>
                }
            </select>

            <select name="locationId">
                <option value="">Todas las localidades</option>
                @foreach (var item in Model.Locations)
                {
                    <option value="@item.Id" selected="@(Model.LocationId == item.Id)">@item.Name (@item.Count)</option>
                }
            </select>

            <button type="submit" class="btn btn-primary">Aplicar filtros</button>
            <a asp-controller="Lobby" asp-action="EngineeringOrders" class="btn btn-secondary">Limpiar</a>
        </form>
    </div>

    <div class="engineering-summary-grid">
        <div class="card">
            <h3>Órdenes por family</h3>
            @if (!Model.FamilySummary.Any())
            {
                <div class="empty">No hay resultados con los filtros actuales.</div>
            }
            else
            {
                <ul class="engineering-breakdown-list">
                    @foreach (var item in Model.FamilySummary)
                    {
                        <li>
                            <span>@item.Label</span>
                            <strong>@item.Count</strong>
                        </li>
                    }
                </ul>
            }
        </div>

        <div class="card">
            <h3>Órdenes por subfamily</h3>
            @if (!Model.SubfamilySummary.Any())
            {
                <div class="empty">No hay resultados con los filtros actuales.</div>
            }
            else
            {
                <ul class="engineering-breakdown-list">
                    @foreach (var item in Model.SubfamilySummary)
                    {
                        <li>
                            <span>@item.Label</span>
                            <strong>@item.Count</strong>
                        </li>
                    }
                </ul>
            }
        </div>

        <div class="card">
            <h3>Órdenes por localidad</h3>
            @if (!Model.LocationSummary.Any())
            {
                <div class="empty">No hay resultados con los filtros actuales.</div>
            }
            else
            {
                <ul class="engineering-breakdown-list">
                    @foreach (var item in Model.LocationSummary)
                    {
                        <li>
                            <span>@item.Label</span>
                            <strong>@item.Count</strong>
                        </li>
                    }
                </ul>
            }
        </div>

        <div class="card">
            <h3>Órdenes por ruta</h3>
            @if (!Model.RouteSummary.Any())
            {
                <div class="empty">No hay resultados con los filtros actuales.</div>
            }
            else
            {
                <ul class="engineering-breakdown-list">
                    @foreach (var item in Model.RouteSummary)
                    {
                        <li>
                            <span>@item.Label</span>
                            <strong>@item.Count</strong>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>

    <div class="card">
        <div class="page-header">
            <div>
                <h3>Listado filtrado de órdenes activas</h3>
                <p class="subtitle">Aquí puedes ver exactamente cuáles órdenes pertenecen a una family, subfamily, ruta o localidad seleccionada.</p>
            </div>
        </div>

        <div class="table-wrapper">
            <table class="table">
                <thead>
                    <tr>
                        <th>WO</th>
                        <th>Producto</th>
                        <th>Estado</th>
                        <th>Family</th>
                        <th>Subfamily</th>
                        <th>Ruta</th>
                        <th>Localidad</th>
                        <th>Inicio WIP</th>
                        <th class="text-right">Días</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="9" class="empty">No hay órdenes que coincidan con los filtros seleccionados.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.WoNumber</td>
                                <td>@item.Product</td>
                                <td>@item.Status</td>
                                <td>@item.Family</td>
                                <td>@item.Subfamily</td>
                                <td>@item.Route</td>
                                <td>@item.Location</td>
                                <td>@(item.WipCreatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                                <td class="text-right">@(item.AgeDays?.ToString() ?? "-")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const familySelect = document.getElementById("familyFilter");
            const subfamilySelect = document.getElementById("subfamilyFilter");
            if (!familySelect || !subfamilySelect) return;

            const options = Array.from(subfamilySelect.options);

            const filterSubfamilies = () => {
                const familyId = familySelect.value;
                options.forEach((option) => {
                    if (!option.value) {
                        option.hidden = false;
                        return;
                    }

                    option.hidden = !!familyId && option.dataset.familyId !== familyId;
                });

                const selected = subfamilySelect.selectedOptions[0];
                if (selected && selected.value && selected.hidden) {
                    subfamilySelect.value = "";
                }
            };

            familySelect.addEventListener("change", filterSubfamilies);
            filterSubfamilies();
        })();
    </script>
}
